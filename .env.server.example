SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=aftertaste://callback
AFTERTASTE_CLOUD_SPOTIFY_REDIRECT_URI=https://aftertaste.mhirth.com/spotify-cloud-callback

AFTERTASTE_API_HOST=0.0.0.0
AFTERTASTE_API_PORT=8765

# Enable Clerk-protected cloud sync endpoints
CLERK_AUTH_ENABLED=1
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLOUD_SIGNIN_BASE_URL=https://aftertaste.mhirth.com
VITE_CLERK_JWT_TEMPLATE=

# Server master mode: automated cloud-side playlist updates
AFTERTASTE_SERVER_MASTER_ENABLED=1
AFTERTASTE_SERVER_MASTER_INTERVAL_SECONDS=180
AFTERTASTE_SERVER_TOKEN_ENCRYPTION_KEY=

# Optional local desktop -> cloud sync settings (desktop clients)
AFTERTASTE_CLOUD_SYNC_ENABLED=0
AFTERTASTE_CLOUD_API_BASE_URL=
AFTERTASTE_CLOUD_CLIENT_ID=desktop-local
AFTERTASTE_CLOUD_SYNC_POLL_SECONDS=60
AFTERTASTE_CLOUD_BEARER_TOKEN=
